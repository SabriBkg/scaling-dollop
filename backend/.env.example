DJANGO_SETTINGS_MODULE=safenet_backend.settings.development
SECRET_KEY=dev-secret-key-change-in-production
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1
DATABASE_URL=postgresql://safenet:safenet@db:5432/safenet
REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/1
STRIPE_TOKEN_KEY=placeholder-fernet-key-generate-with-Fernet.generate_key()
SENTRY_DSN=

# Public base URL for SafeNet's own surfaces (subscriber opt-out links).
# Production default lives in settings/base.py; local dev overrides here so
# emails sent from a docker-compose backend point at the local server.
SAFENET_BASE_URL=http://localhost:8000

# Public frontend URL (Next.js) — distinct from SAFENET_BASE_URL because in
# dev the backend is at :8000 and the frontend is at :3000. In production
# they may share a domain via reverse proxy.
SAFENET_FRONTEND_URL=http://localhost:3000

# Stripe Connect OAuth
STRIPE_CLIENT_ID=ca_...              # From Stripe Dashboard → Connect → Settings
STRIPE_SECRET_KEY=sk_test_...        # Stripe secret key (test mode for dev)
STRIPE_REDIRECT_URI=http://localhost:3000/register/callback  # Must match Stripe Dashboard setting
